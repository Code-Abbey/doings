# MongoDB Atlas connection string — include the database name before the ?
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/doings?retryWrites=true&w=majority&appName=Cluster0

# JWT secret — use a long random string
JWT_SECRET=your_long_random_secret_here

# Admin invite token — shared with users who should register as admin
ADMIN_INVITE_TOKEN=your_admin_token_here

# Allowed frontend origin (e.g. https://code-abbey.github.io for GitHub Pages)
CLIENT_URL=http://localhost:5173

# Server port
PORT=8000
